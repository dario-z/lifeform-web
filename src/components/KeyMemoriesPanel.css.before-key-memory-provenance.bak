.key-memory-backdrop {
  position: fixed;
  z-index: 11000;
  inset: 0;
  display: flex;
  justify-content: flex-end;
  background: rgba(0, 0, 0, 0.58);
  backdrop-filter: blur(5px);
}

.key-memory-panel {
  width: min(560px, 100vw);
  height: 100vh;
  height: 100dvh;
  box-sizing: border-box;
  overflow-y: auto;
  padding: 26px;
  color: var(--p5-text, #e6e6eb);
  background:
    linear-gradient(
      155deg,
      rgba(255, 39, 64, 0.14),
      transparent 32%
    ),
    #111217;
  border-left: 1px solid
    rgba(255, 255, 255, 0.12);
  box-shadow: -26px 0 70px
    rgba(0, 0, 0, 0.52);
}

.key-memory-header {
  position: sticky;
  z-index: 2;
  top: -26px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin: -26px -26px 0;
  padding: 26px 26px 20px;
  background:
    linear-gradient(
      155deg,
      rgba(255, 39, 64, 0.15),
      transparent 44%
    ),
    #111217;
  border-bottom: 1px solid
    rgba(255, 255, 255, 0.1);
}

.key-memory-header h2 {
  margin: 0;
  color: #fff;
  font-family:
    Impact,
    Haettenschweiler,
    "Arial Narrow Bold",
    sans-serif;
  font-size: clamp(2rem, 7vw, 2.8rem);
  font-style: italic;
  line-height: 0.94;
  text-transform: uppercase;
}

.key-memory-header > div > p:last-child {
  margin: 8px 0 0;
  color: #8f929d;
  font-size: 0.75rem;
}

.key-memory-close {
  width: 42px;
  height: 42px;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  color: #fff;
  font-size: 1.7rem;
  background: #292b33;
  cursor: pointer;
}

.key-memory-close:hover {
  background: var(--p5-red, #ff2740);
}

.key-memory-intro,
.key-memory-error {
  margin: 18px 0;
  padding: 12px 14px;
  font-size: 0.78rem;
  line-height: 1.55;
}

.key-memory-intro {
  color: #b9bbc4;
  background: rgba(255, 255, 255, 0.035);
  border-left: 3px solid
    var(--p5-red, #ff2740);
}

.key-memory-error {
  color: #ffbdc7;
  background: rgba(255, 39, 64, 0.1);
  border: 1px solid
    rgba(255, 39, 64, 0.32);
}

.key-memory-add {
  width: 100%;
  min-height: 46px;
  margin-bottom: 16px;
  color: #fff;
  font-weight: 900;
  text-transform: uppercase;
  background: #23252d;
  border: 1px dashed
    rgba(255, 255, 255, 0.18);
  cursor: pointer;
}

.key-memory-add:hover:not(:disabled) {
  background: #2d3039;
  border-color: var(--p5-red, #ff2740);
}

.key-memory-add:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.key-memory-editor {
  display: grid;
  gap: 15px;
  margin: 18px 0;
  padding: 16px;
  background: rgba(0, 0, 0, 0.25);
  border: 1px solid
    rgba(255, 255, 255, 0.1);
}

.key-memory-editor label {
  display: grid;
  gap: 7px;
}

.key-memory-editor label > span {
  color: #c8cad2;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.key-memory-editor select,
.key-memory-editor textarea {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  padding: 11px 12px;
  color: #fff;
  background: #0d0e13;
  border: 1px solid #30323b;
  outline: none;
}

.key-memory-editor textarea {
  resize: vertical;
  line-height: 1.5;
}

.key-memory-editor select:focus,
.key-memory-editor textarea:focus {
  border-color: var(--p5-red, #ff2740);
  box-shadow: 0 0 0 3px
    rgba(255, 39, 64, 0.15);
}

.key-memory-editor input[type="range"] {
  width: 100%;
  accent-color: var(--p5-red, #ff2740);
}

.key-memory-editor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.key-memory-list {
  display: grid;
  gap: 12px;
  padding-bottom: 20px;
}

.key-memory-card {
  padding: 14px;
  background: rgba(255, 255, 255, 0.035);
  border: 1px solid
    rgba(255, 255, 255, 0.09);
  border-left: 3px solid
    rgba(255, 39, 64, 0.7);
}

.key-memory-card-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 9px;
  color: #8f929d;
  font-size: 0.64rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.key-memory-card-topline span:first-child {
  color: var(--p5-red, #ff2740);
}

.key-memory-card p {
  margin: 0;
  color: #ebebef;
  font-size: 0.86rem;
  line-height: 1.58;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
}

.key-memory-card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 12px;
}

.key-memory-card-actions button {
  min-height: 34px;
  padding: 6px 10px;
  color: #d8dae1;
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  background: #22242c;
  border: 1px solid
    rgba(255, 255, 255, 0.08);
  cursor: pointer;
}

.key-memory-card-actions button:hover:not(:disabled) {
  color: #fff;
  border-color: var(--p5-red, #ff2740);
}

.key-memory-empty {
  margin: 20px 0;
  color: #8f929d;
  font-size: 0.82rem;
  line-height: 1.6;
  text-align: center;
}

@media (max-width: 620px) {
  .key-memory-panel {
    width: 100vw;
    padding: 20px 15px;
  }

  .key-memory-header {
    top: -20px;
    margin: -20px -15px 0;
    padding: 20px 15px 17px;
  }

  .key-memory-editor-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
}
