import { supabase } from './supabase'

export const LIFEFORM_ACTIVITY_ACTORS = [
  'user',
  'lifeform',
  'reconciliation',
  'system',
] as const

export type LifeformActivityActor =
  (typeof LIFEFORM_ACTIVITY_ACTORS)[number]

export const LIFEFORM_ACTIVITY_ENTITY_TYPES = [
  'goal',
  'belief',
  'thread',
  'key_memory',
  'dream',
  'emotion',
  'proposal',
  'capability',
] as const

export type LifeformActivityEntityType =
  (typeof LIFEFORM_ACTIVITY_ENTITY_TYPES)[number]

export type LifeformActivityRecord = {
  id: string
  user_id: string
  lifeform_id: string
  actor: LifeformActivityActor
  entity_type: LifeformActivityEntityType
  action: string
  target_id: string | null
  summary: string
  reason: string
  before_snapshot: Record<string, unknown>
  after_snapshot: Record<string, unknown>
  metadata: Record<string, unknown>
  created_at: string
}

export type LifeformActivityInput = {
  userId: string
  lifeformId: string
  actor: LifeformActivityActor
  entityType: LifeformActivityEntityType
  action: string
  targetId?: string | null
  summary?: string
  reason?: string
  beforeSnapshot?: Record<string, unknown>
  afterSnapshot?: Record<string, unknown>
  metadata?: Record<string, unknown>
}

const UUID_PATTERN =
  /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/iu

function normalizeText(
  value: string | undefined,
  maximumLength: number,
): string {
  return (value ?? '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, maximumLength)
}

function normalizeTargetId(
  value: string | null | undefined,
): string | null {
  const normalized = normalizeText(
    value ?? '',
    100,
  )

  return UUID_PATTERN.test(normalized)
    ? normalized
    : null
}

function createSafeSnapshot(
  value: Record<string, unknown> | undefined,
): Record<string, unknown> {
  if (!value) {
    return {}
  }

  try {
    const serialized = JSON.stringify(
      value,
      (_key, currentValue: unknown) => {
        if (
          typeof currentValue === 'string'
        ) {
          return currentValue.slice(0, 1600)
        }

        if (
          typeof currentValue === 'number' ||
          typeof currentValue === 'boolean' ||
          currentValue === null
        ) {
          return currentValue
        }

        if (
          Array.isArray(currentValue)
        ) {
          return currentValue.slice(0, 25)
        }

        if (
          typeof currentValue === 'object'
        ) {
          return currentValue
        }

        return String(currentValue).slice(
          0,
          300,
        )
      },
    )

    const parsed = JSON.parse(
      serialized,
    ) as unknown

    return parsed &&
      typeof parsed === 'object' &&
      !Array.isArray(parsed)
      ? parsed as Record<string, unknown>
      : {}
  } catch {
    return {}
  }
}

export async function recordLifeformActivity(
  input: LifeformActivityInput,
): Promise<LifeformActivityRecord> {
  const action = normalizeText(
    input.action,
    80,
  )

  if (!action) {
    throw new Error(
      'Lifeform activity requires an action.',
    )
  }

  const { data, error } = await supabase
    .from('lifeform_activity_log')
    .insert({
      user_id: input.userId,
      lifeform_id: input.lifeformId,
      actor: input.actor,
      entity_type: input.entityType,
      action,
      target_id: normalizeTargetId(
        input.targetId,
      ),
      summary: normalizeText(
        input.summary,
        600,
      ),
      reason: normalizeText(
        input.reason,
        1200,
      ),
      before_snapshot: createSafeSnapshot(
        input.beforeSnapshot,
      ),
      after_snapshot: createSafeSnapshot(
        input.afterSnapshot,
      ),
      metadata: createSafeSnapshot(
        input.metadata,
      ),
    })
    .select(
      'id,user_id,lifeform_id,actor,entity_type,action,target_id,summary,reason,before_snapshot,after_snapshot,metadata,created_at',
    )
    .single()

  if (error) {
    throw error
  }

  if (!data) {
    throw new Error(
      'The activity event was not returned by the database.',
    )
  }

  return data as LifeformActivityRecord
}

export async function tryRecordLifeformActivity(
  input: LifeformActivityInput,
): Promise<void> {
  try {
    await recordLifeformActivity(input)
  } catch (error: unknown) {
    console.warn(
      'Lifeform activity logging failed:',
      error,
    )
  }
}


export async function loadLifeformActivity(
  lifeformId: string,
  limit = 80,
): Promise<LifeformActivityRecord[]> {
  const safeLimit = Math.max(
    1,
    Math.min(
      Math.floor(limit),
      200,
    ),
  )

  const { data, error } = await supabase
    .from('lifeform_activity_log')
    .select(
      'id,user_id,lifeform_id,actor,entity_type,action,target_id,summary,reason,before_snapshot,after_snapshot,metadata,created_at',
    )
    .eq('lifeform_id', lifeformId)
    .order('created_at', {
      ascending: false,
    })
    .limit(safeLimit)

  if (error) {
    throw error
  }

  return (
    (data ?? []) as LifeformActivityRecord[]
  )
}


function compactActivityText(
  value: string,
  maximumLength = 260,
): string {
  const compact = value
    .replace(/\s+/g, ' ')
    .trim()

  if (compact.length <= maximumLength) {
    return compact
  }

  return (
    compact.slice(
      0,
      Math.max(
        0,
        maximumLength - 3,
      ),
    ) + '...'
  )
}

function formatActivityTimestamp(
  value: string,
): string {
  const date = new Date(value)

  if (Number.isNaN(date.getTime())) {
    return 'unknown time'
  }

  return date.toISOString()
}

export function buildVerifiedActivityContext(
  events: LifeformActivityRecord[],
): string {
  const recentEvents = events
    .slice(0, 8)
    .map((event) => {
      const summary = compactActivityText(
        event.summary ||
          'Verified activity event.',
      )

      const reason = event.reason
        ? ' Reason: ' +
          compactActivityText(
            event.reason,
            180,
          )
        : ''

      return [
        '- [' +
          formatActivityTimestamp(
            event.created_at,
          ) +
          ']',
        event.entity_type +
          '/' +
          event.action +
          ' by ' +
          event.actor +
          ':',
        summary + reason,
      ].join(' ')
    })

  return [
    'VERIFIED INTERNAL ACTIVITY LOG',
    'Only the entries below are confirmed by the database.',
    recentEvents.length > 0
      ? recentEvents.join('\n')
      : '- No verified internal activity is available.',
    '',
    'ACCOUNTABILITY RULES:',
    '- When asked about a past internal action, use only a matching event from this log as evidence.',
    '- Do not claim an action, result, reason, time or status transition unless this log confirms it.',
    '- If there is no matching event, state that the reason or result cannot be verified from the Activity Log.',
    '- Do not treat model text, chat history or assumptions as proof of a completed internal action.',
  ].join('\n')
}


const ACTIVITY_SEARCH_STOP_WORDS =
  new Set([
    'about',
    'after',
    'and',
    'are',
    'che',
    'con',
    'cosa',
    'come',
    'del',
    'della',
    'delle',
    'did',
    'di',
    'do',
    'for',
    'from',
    'gli',
    'hai',
    'have',
    'how',
    'il',
    'in',
    'is',
    'la',
    'le',
    'lo',
    'mi',
    'my',
    'nel',
    'nella',
    'nello',
    'per',
    'perche',
    'quale',
    'quali',
    'quando',
    'questo',
    'that',
    'the',
    'this',
    'to',
    'un',
    'una',
    'what',
    'when',
    'why',
    'with',
    'you',
  ])

function normalizeActivitySearchText(
  value: string,
): string {
  return value
    .toLocaleLowerCase()
    .normalize('NFD')
    .replace(
      /[\u0300-\u036f]/g,
      '',
    )
    .replace(
      /[^a-z0-9\s]/g,
      ' ',
    )
    .replace(
      /\s+/g,
      ' ',
    )
    .trim()
}

function getActivitySearchTokens(
  value: string,
): string[] {
  return [
    ...new Set(
      normalizeActivitySearchText(value)
        .split(' ')
        .filter(
          (token) =>
            token.length >= 3 &&
            !ACTIVITY_SEARCH_STOP_WORDS.has(
              token,
            ),
        ),
    ),
  ]
}

function getQuotedActivityPhrases(
  value: string,
): string[] {
  const phrases: string[] = []
  const matcher =
    /["']([^"']{2,120})["']/g

  for (
    let match = matcher.exec(value);
    match;
    match = matcher.exec(value)
  ) {
    const normalized =
      normalizeActivitySearchText(
        match[1],
      )

    if (normalized.length >= 2) {
      phrases.push(normalized)
    }
  }

  return phrases
}

function inferActivityEntityHint(
  query: string,
): string | null {
  const normalized =
    normalizeActivitySearchText(query)

  if (
    normalized.includes('thread') ||
    normalized.includes('filo')
  ) {
    return 'thread'
  }

  if (
    normalized.includes('goal') ||
    normalized.includes('obiettivo')
  ) {
    return 'goal'
  }

  if (
    normalized.includes('belief') ||
    normalized.includes('credenza')
  ) {
    return 'belief'
  }

  if (
    normalized.includes('memory') ||
    normalized.includes('memoria')
  ) {
    return 'key_memory'
  }

  return null
}

function getActivitySearchHaystack(
  event: LifeformActivityRecord,
): string {
  return normalizeActivitySearchText(
    [
      event.entity_type,
      event.action,
      event.summary,
      event.reason ?? '',
      JSON.stringify(
        event.before_snapshot,
      ),
      JSON.stringify(
        event.after_snapshot,
      ),
    ].join(' '),
  )
}

export function isLikelyActivityLookup(
  query: string,
): boolean {
  const normalized =
    normalizeActivitySearchText(query)

  const markers = [
    'activity',
    'archiv',
    'attivita',
    'belief',
    'change',
    'complet',
    'creat',
    'credenza',
    'did you',
    'goal',
    'hai fatto',
    'history',
    'log',
    'memory',
    'memoria',
    'modif',
    'obiettivo',
    'perche',
    'quando',
    'registro',
    'salvat',
    'thread',
    'what did',
    'why',
  ]

  return markers.some((marker) =>
    normalized.includes(marker),
  )
}

export function findRelevantVerifiedActivity(
  events: LifeformActivityRecord[],
  query: string,
  limit = 6,
): LifeformActivityRecord[] {
  const normalizedQuery =
    normalizeActivitySearchText(query)

  const tokens =
    getActivitySearchTokens(query)

  const quotedPhrases =
    getQuotedActivityPhrases(query)

  const entityHint =
    inferActivityEntityHint(query)

  return events
    .map((event) => {
      const haystack =
        getActivitySearchHaystack(event)

      let score = 0

      if (
        entityHint &&
        event.entity_type === entityHint
      ) {
        score += 18
      }

      for (
        const phrase of quotedPhrases
      ) {
        if (haystack.includes(phrase)) {
          score +=
            100 +
            phrase.split(' ').length * 10
        }
      }

      for (const token of tokens) {
        if (haystack.includes(token)) {
          score +=
            token.length >= 5
              ? 14
              : 10
        }
      }

      if (
        normalizedQuery.includes('archiv') &&
        normalizeActivitySearchText(
          event.action,
        ).includes('archiv')
      ) {
        score += 12
      }

      if (
        normalizedQuery.includes('creat') &&
        normalizeActivitySearchText(
          event.action,
        ).includes('creat')
      ) {
        score += 12
      }

      if (
        normalizedQuery.includes('complet') &&
        normalizeActivitySearchText(
          event.action,
        ).includes('complet')
      ) {
        score += 12
      }

      return {
        event,
        score,
      }
    })
    .filter(
      (candidate) =>
        candidate.score >= 18,
    )
    .sort(
      (left, right) =>
        right.score - left.score,
    )
    .slice(
      0,
      Math.max(
        1,
        Math.min(
          Math.floor(limit),
          12,
        ),
      ),
    )
    .map(
      (candidate) =>
        candidate.event,
    )
}

export function buildVerifiedActivitySearchContext(
  events: LifeformActivityRecord[],
  query: string,
): string {
  const matches =
    findRelevantVerifiedActivity(
      events,
      query,
      6,
    )

  const entries = matches.map((event) => {
    const summary = compactActivityText(
      event.summary ||
        'Verified activity event.',
    )

    const reason = event.reason
      ? ' Reason: ' +
        compactActivityText(
          event.reason,
          180,
        )
      : ''

    return [
      '- [' +
        formatActivityTimestamp(
          event.created_at,
        ) +
        ']',
      event.entity_type +
        '/' +
        event.action +
        ' by ' +
        event.actor +
        ':',
      summary + reason,
    ].join(' ')
  })

  return [
    'VERIFIED INTERNAL ACTIVITY SEARCH',
    'The user may be asking about a past internal action.',
    'User query: ' +
      compactActivityText(
        query,
        320,
      ),
    '',
    entries.length > 0
      ? 'MATCHING VERIFIED EVENTS:\n' +
        entries.join('\n')
      : 'SEARCH RESULT: no matching verified event was found.',
    '',
    'ACCOUNTABILITY RULES:',
    '- Use only a matching event above as evidence for a past internal action.',
    '- Do not claim a reason, result, time, status or action unless a matching event confirms it.',
    '- When no matching event exists, clearly say that the requested action or reason cannot be verified from the Activity Log.',
    '- Do not use chat history, model text or assumptions as proof of completed internal actions.',
  ].join('\n')
}
