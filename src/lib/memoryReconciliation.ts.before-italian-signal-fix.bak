import { GoogleGenAI } from '@google/genai'
import {
  DEFAULT_GEMINI_MODEL,
  EMPTY_GEMINI_TOKEN_USAGE,
  getGeminiTokenUsage,
  type GeminiModelId,
  type GeminiTokenUsage,
} from './geminiModels'
import type {
  LifeformBelief,
  LifeformBeliefStatus,
  LifeformGoal,
  LifeformGoalStatus,
} from '../types/lifeformIdentity'
import type {
  LifeformThread,
  LifeformThreadStatus,
} from '../types/lifeformThread'
import type {
  KeyMemory,
  KeyMemoryStatus,
} from '../types/keyMemory'

type ReconciliationHistoryMessage = {
  role: 'user' | 'assistant'
  content: string
}

type ReconcileMemoryLifecycleOptions = {
  apiKey: string
  model?: GeminiModelId
  lifeformName: string
  lifeformLanguage: string
  recentHistory: ReconciliationHistoryMessage[]
  userMessage: string
  assistantResponse: string
  threads: LifeformThread[]
  goals: LifeformGoal[]
  beliefs: LifeformBelief[]
  keyMemories: KeyMemory[]
}

export type ThreadLifecycleMutation = {
  id: string
  status: LifeformThreadStatus
  statusReason: string
  currentContext: string
  lastProgress: string
  openDirection: string
}

export type GoalLifecycleMutation = {
  id: string
  status: LifeformGoalStatus
  statusReason: string
  progress: number | null
  nextStep: string
  blockedReason: string
}

export type BeliefLifecycleMutation = {
  id: string
  status: LifeformBeliefStatus
  statusReason: string
  supersededById: string | null
  confirm: boolean
}

export type KeyMemoryLifecycleMutation = {
  id: string
  status: KeyMemoryStatus
  statusReason: string
  supersededById: string | null
}

export type MemoryReconciliationResult = {
  source: 'model' | 'skipped' | 'fallback'
  tokenUsage: GeminiTokenUsage
  threads: ThreadLifecycleMutation[]
  goals: GoalLifecycleMutation[]
  beliefs: BeliefLifecycleMutation[]
  keyMemories: KeyMemoryLifecycleMutation[]
  error: string | null
}

type RawRecord = Record<string, unknown>

type RawReconciliation = {
  threads?: unknown
  goals?: unknown
  beliefs?: unknown
  keyMemories?: unknown
}

const THREAD_STATUSES = [
  'active',
  'paused',
  'resolved',
  'abandoned',
  'archived',
] as const

const GOAL_STATUSES = [
  'active',
  'paused',
  'blocked',
  'completed',
  'abandoned',
  'archived',
] as const

const BELIEF_STATUSES = [
  'active',
  'superseded',
  'retracted',
  'archived',
] as const

const KEY_MEMORY_STATUSES = [
  'active',
  'temporary',
  'superseded',
  'archived',
] as const

const lifecycleResponseSchema = {
  type: 'object',
  properties: {
    threads: {
      type: 'array',
      items: {
        type: 'object',
        properties: {
          id: { type: 'string' },
          status: {
            type: 'string',
            enum: [...THREAD_STATUSES],
          },
          statusReason: { type: 'string' },
          currentContext: { type: 'string' },
          lastProgress: { type: 'string' },
          openDirection: { type: 'string' },
        },
        required: [
          'id',
          'status',
          'statusReason',
          'currentContext',
          'lastProgress',
          'openDirection',
        ],
        additionalProperties: false,
      },
    },
    goals: {
      type: 'array',
      items: {
        type: 'object',
        properties: {
          id: { type: 'string' },
          status: {
            type: 'string',
            enum: [...GOAL_STATUSES],
          },
          statusReason: { type: 'string' },
          progress: { type: 'integer' },
          nextStep: { type: 'string' },
          blockedReason: { type: 'string' },
        },
        required: [
          'id',
          'status',
          'statusReason',
          'progress',
          'nextStep',
          'blockedReason',
        ],
        additionalProperties: false,
      },
    },
    beliefs: {
      type: 'array',
      items: {
        type: 'object',
        properties: {
          id: { type: 'string' },
          status: {
            type: 'string',
            enum: [...BELIEF_STATUSES],
          },
          statusReason: { type: 'string' },
          supersededById: { type: 'string' },
          confirm: { type: 'boolean' },
        },
        required: [
          'id',
          'status',
          'statusReason',
          'supersededById',
          'confirm',
        ],
        additionalProperties: false,
      },
    },
    keyMemories: {
      type: 'array',
      items: {
        type: 'object',
        properties: {
          id: { type: 'string' },
          status: {
            type: 'string',
            enum: [...KEY_MEMORY_STATUSES],
          },
          statusReason: { type: 'string' },
          supersededById: { type: 'string' },
        },
        required: [
          'id',
          'status',
          'statusReason',
          'supersededById',
        ],
        additionalProperties: false,
      },
    },
  },
  required: [
    'threads',
    'goals',
    'beliefs',
    'keyMemories',
  ],
  additionalProperties: false,
}

const lifecycleSignalPattern =
  /\b(?:finito|finita|finiti|finite|completato|completata|completati|completate|concluso|conclusa|chiuso|chiusa|chiusi|chiuse|risolto|risolta|risolti|risolte|abbandono|abbandonare|abbandonato|abbandonata|smetto|smettere|interrotto|interrotta|pausa|fermato|fermata|bloccato|bloccata|non\s+piu|cambiato|cambiata|cambiati|cambiate|preferisco|sostituito|sostituita|aggiornato|aggiornata|rimosso|rimossa|retracted|superseded|finished|completed|resolved|closed|abandoned|paused|blocked|stopped|changed|replaced|no\s+longer|from\s+now\s+on|i\s+prefer)\b/iu

function createEmptyResult(
  source: MemoryReconciliationResult['source'],
  error: string | null = null,
): MemoryReconciliationResult {
  return {
    source,
    tokenUsage: {
      ...EMPTY_GEMINI_TOKEN_USAGE,
    },
    threads: [],
    goals: [],
    beliefs: [],
    keyMemories: [],
    error,
  }
}

function asRecord(value: unknown): RawRecord | null {
  return value &&
    typeof value === 'object' &&
    !Array.isArray(value)
    ? value as RawRecord
    : null
}

function asArray(value: unknown): unknown[] {
  return Array.isArray(value)
    ? value
    : []
}

function normalizeText(
  value: unknown,
  maximumLength: number,
): string {
  return typeof value === 'string'
    ? value
        .replace(/\s+/g, ' ')
        .trim()
        .slice(0, maximumLength)
    : ''
}

function normalizeId(value: unknown): string {
  return normalizeText(value, 100)
}

function clamp(
  value: number,
  minimum: number,
  maximum: number,
): number {
  return Math.min(
    maximum,
    Math.max(minimum, value),
  )
}

function normalizeProgress(
  value: unknown,
): number | null {
  const numeric =
    typeof value === 'number'
      ? value
      : Number(value)

  if (!Number.isFinite(numeric)) {
    return null
  }

  if (numeric < 0) {
    return null
  }

  return clamp(
    Math.round(numeric),
    0,
    100,
  )
}

function isAllowedStatus<T extends string>(
  value: unknown,
  allowed: readonly T[],
): value is T {
  return (
    typeof value === 'string' &&
    allowed.includes(value as T)
  )
}

function dedupeById<
  T extends { id: string },
>(
  items: T[],
): T[] {
  const seen = new Set<string>()

  return items.filter((item) => {
    if (seen.has(item.id)) {
      return false
    }

    seen.add(item.id)
    return true
  })
}

function normalizeThreadMutation(
  value: unknown,
  allowedIds: Set<string>,
): ThreadLifecycleMutation | null {
  const record = asRecord(value)

  if (!record) {
    return null
  }

  const id = normalizeId(record.id)

  if (
    !id ||
    !allowedIds.has(id) ||
    !isAllowedStatus(
      record.status,
      THREAD_STATUSES,
    )
  ) {
    return null
  }

  const statusReason = normalizeText(
    record.statusReason,
    280,
  )

  if (statusReason.length < 8) {
    return null
  }

  return {
    id,
    status: record.status,
    statusReason,
    currentContext: normalizeText(
      record.currentContext,
      900,
    ),
    lastProgress: normalizeText(
      record.lastProgress,
      700,
    ),
    openDirection: normalizeText(
      record.openDirection,
      700,
    ),
  }
}

function normalizeGoalMutation(
  value: unknown,
  allowedIds: Set<string>,
): GoalLifecycleMutation | null {
  const record = asRecord(value)

  if (!record) {
    return null
  }

  const id = normalizeId(record.id)

  if (
    !id ||
    !allowedIds.has(id) ||
    !isAllowedStatus(
      record.status,
      GOAL_STATUSES,
    )
  ) {
    return null
  }

  const statusReason = normalizeText(
    record.statusReason,
    280,
  )

  if (statusReason.length < 8) {
    return null
  }

  return {
    id,
    status: record.status,
    statusReason,
    progress: normalizeProgress(
      record.progress,
    ),
    nextStep: normalizeText(
      record.nextStep,
      500,
    ),
    blockedReason: normalizeText(
      record.blockedReason,
      500,
    ),
  }
}

function normalizeBeliefMutation(
  value: unknown,
  allowedIds: Set<string>,
): BeliefLifecycleMutation | null {
  const record = asRecord(value)

  if (!record) {
    return null
  }

  const id = normalizeId(record.id)

  if (
    !id ||
    !allowedIds.has(id) ||
    !isAllowedStatus(
      record.status,
      BELIEF_STATUSES,
    )
  ) {
    return null
  }

  const statusReason = normalizeText(
    record.statusReason,
    280,
  )

  if (statusReason.length < 8) {
    return null
  }

  const supersededById = normalizeId(
    record.supersededById,
  )

  if (
    record.status === 'superseded' &&
    (
      !supersededById ||
      supersededById === id ||
      !allowedIds.has(supersededById)
    )
  ) {
    return null
  }

  return {
    id,
    status: record.status,
    statusReason,
    supersededById:
      supersededById &&
      supersededById !== id &&
      allowedIds.has(supersededById)
        ? supersededById
        : null,
    confirm: record.confirm === true,
  }
}

function normalizeKeyMemoryMutation(
  value: unknown,
  allowedIds: Set<string>,
): KeyMemoryLifecycleMutation | null {
  const record = asRecord(value)

  if (!record) {
    return null
  }

  const id = normalizeId(record.id)

  if (
    !id ||
    !allowedIds.has(id) ||
    !isAllowedStatus(
      record.status,
      KEY_MEMORY_STATUSES,
    )
  ) {
    return null
  }

  const statusReason = normalizeText(
    record.statusReason,
    280,
  )

  if (statusReason.length < 8) {
    return null
  }

  const supersededById = normalizeId(
    record.supersededById,
  )

  if (
    record.status === 'superseded' &&
    (
      !supersededById ||
      supersededById === id ||
      !allowedIds.has(supersededById)
    )
  ) {
    return null
  }

  return {
    id,
    status: record.status,
    statusReason,
    supersededById:
      supersededById &&
      supersededById !== id &&
      allowedIds.has(supersededById)
        ? supersededById
        : null,
  }
}

function parseReconciliation(
  value: unknown,
  threads: LifeformThread[],
  goals: LifeformGoal[],
  beliefs: LifeformBelief[],
  keyMemories: KeyMemory[],
): Omit<
  MemoryReconciliationResult,
  'source' | 'tokenUsage' | 'error'
> {
  const parsed = asRecord(value) as
    RawReconciliation | null

  if (!parsed) {
    return {
      threads: [],
      goals: [],
      beliefs: [],
      keyMemories: [],
    }
  }

  const threadIds = new Set(
    threads.map((thread) => thread.id),
  )
  const goalIds = new Set(
    goals.map((goal) => goal.id),
  )
  const beliefIds = new Set(
    beliefs.map((belief) => belief.id),
  )
  const keyMemoryIds = new Set(
    keyMemories.map((memory) => memory.id),
  )

  return {
    threads: dedupeById(
      asArray(parsed.threads)
        .map((item) =>
          normalizeThreadMutation(
            item,
            threadIds,
          ),
        )
        .filter(
          (
            item,
          ): item is ThreadLifecycleMutation =>
            item !== null,
        ),
    ).slice(0, 1),

    goals: dedupeById(
      asArray(parsed.goals)
        .map((item) =>
          normalizeGoalMutation(
            item,
            goalIds,
          ),
        )
        .filter(
          (
            item,
          ): item is GoalLifecycleMutation =>
            item !== null,
        ),
    ).slice(0, 1),

    beliefs: dedupeById(
      asArray(parsed.beliefs)
        .map((item) =>
          normalizeBeliefMutation(
            item,
            beliefIds,
          ),
        )
        .filter(
          (
            item,
          ): item is BeliefLifecycleMutation =>
            item !== null,
        ),
    ).slice(0, 1),

    keyMemories: dedupeById(
      asArray(parsed.keyMemories)
        .map((item) =>
          normalizeKeyMemoryMutation(
            item,
            keyMemoryIds,
          ),
        )
        .filter(
          (
            item,
          ): item is KeyMemoryLifecycleMutation =>
            item !== null,
        ),
    ).slice(0, 1),
  }
}

function buildSnapshot({
  threads,
  goals,
  beliefs,
  keyMemories,
}: Pick<
  ReconcileMemoryLifecycleOptions,
  | 'threads'
  | 'goals'
  | 'beliefs'
  | 'keyMemories'
>) {
  return {
    threads: threads.map((thread) => ({
      id: thread.id,
      title: thread.title,
      status: thread.status,
      currentContext: thread.current_context,
      lastProgress: thread.last_progress,
      openDirection: thread.open_direction,
      linkedGoalId: thread.linked_goal_id,
      updatedAt: thread.updated_at,
    })),

    goals: goals.map((goal) => ({
      id: goal.id,
      content: goal.content,
      importance: goal.importance,
      progress: goal.progress,
      nextStep: goal.next_step,
      blockedReason: goal.blocked_reason,
      status: goal.status,
      updatedAt: goal.updated_at,
    })),

    beliefs: beliefs.map((belief) => ({
      id: belief.id,
      content: belief.content,
      importance: belief.importance,
      status: belief.status,
      source: belief.source,
      updatedAt: belief.updated_at,
    })),

    keyMemories: keyMemories.map((memory) => ({
      id: memory.id,
      category: memory.category,
      content: memory.content,
      importance: memory.importance,
      status: memory.status,
      source: memory.source,
      updatedAt: memory.updated_at,
    })),
  }
}

export function shouldReconcileMemoryLifecycle({
  userMessage,
  threads,
  goals,
  beliefs,
  keyMemories,
}: Pick<
  ReconcileMemoryLifecycleOptions,
  | 'userMessage'
  | 'threads'
  | 'goals'
  | 'beliefs'
  | 'keyMemories'
>): boolean {
  if (
    threads.length === 0 &&
    goals.length === 0 &&
    beliefs.length === 0 &&
    keyMemories.length === 0
  ) {
    return false
  }

  const normalized = userMessage
    .replace(/\s+/g, ' ')
    .trim()

  return (
    normalized.length >= 12 &&
    lifecycleSignalPattern.test(normalized)
  )
}

export async function reconcileMemoryLifecycle({
  apiKey,
  model = DEFAULT_GEMINI_MODEL,
  lifeformName,
  lifeformLanguage,
  recentHistory,
  userMessage,
  assistantResponse,
  threads,
  goals,
  beliefs,
  keyMemories,
}: ReconcileMemoryLifecycleOptions):
  Promise<MemoryReconciliationResult> {
  if (
    !shouldReconcileMemoryLifecycle({
      userMessage,
      threads,
      goals,
      beliefs,
      keyMemories,
    })
  ) {
    return createEmptyResult('skipped')
  }

  try {
    const client = new GoogleGenAI({
      apiKey,
    })

    const snapshot = buildSnapshot({
      threads,
      goals,
      beliefs,
      keyMemories,
    })

    const prompt = [
      'You are a conservative lifecycle reconciler for a persistent AI companion named ' +
        lifeformName +
        '.',
      'The companion language is "' +
        lifeformLanguage +
        '".',
      '',
      'Your task is to reconcile ONLY existing saved records with clear, explicit evidence from the latest user message.',
      'Do not create any new Thread, Goal, Belief or Key Memory.',
      'Do not infer progress, completion, abandonment, preference changes or belief changes from a vague mood, a question, a hypothetical statement, or from the assistant response alone.',
      'The latest explicit statement from the user overrides old saved wording when it clearly conflicts.',
      'When uncertain, return empty arrays.',
      'Return at most one mutation for each collection.',
      '',
      'Status meanings:',
      '- Thread: active = continuing; paused = intentionally deferred; resolved = reached a natural conclusion; abandoned = explicitly dropped; archived = inactive historical context.',
      '- Goal: active = ongoing; paused = intentionally deferred; blocked = cannot progress because of a stated obstacle; completed = explicitly achieved; abandoned = explicitly given up; archived = inactive historical record.',
      '- Belief: active = still held; superseded = replaced by another existing Belief ID; retracted = explicitly no longer held without a replacement; archived = inactive historical record.',
      '- Key Memory: active = durable current context; temporary = explicitly short-lived; superseded = replaced by another existing Key Memory ID; archived = obsolete or no longer useful.',
      '',
      'Rules for fields:',
      '- Use empty strings for thread text fields that should not change.',
      '- Use progress -1 when a Goal progress value should not change.',
      '- Use empty strings for Goal nextStep and blockedReason when they should not change.',
      '- A Belief or Key Memory marked superseded must point to another supplied record ID from the same collection.',
      '- Never alter a manual Key Memory content. You may only change its lifecycle status when the user has clearly contradicted or invalidated it.',
      '- statusReason must be a concise factual explanation based on the user message, not a speculative interpretation.',
      '',
      'Recent conversation:',
      JSON.stringify(
        recentHistory
          .slice(-4)
          .map((message) => ({
            role: message.role,
            content: message.content.slice(0, 700),
          })),
      ),
      '',
      'Latest user message:',
      userMessage.slice(0, 4000),
      '',
      'Assistant response:',
      assistantResponse.slice(0, 4000),
      '',
      'Existing saved records:',
      JSON.stringify(snapshot),
      '',
      'Return JSON only with this exact shape:',
      JSON.stringify({
        threads: [
          {
            id: 'existing-thread-id',
            status: 'resolved',
            statusReason:
              'The user explicitly said the work is finished.',
            currentContext: '',
            lastProgress: '',
            openDirection: '',
          },
        ],
        goals: [
          {
            id: 'existing-goal-id',
            status: 'completed',
            statusReason:
              'The user explicitly said the goal was achieved.',
            progress: 100,
            nextStep: '',
            blockedReason: '',
          },
        ],
        beliefs: [
          {
            id: 'existing-belief-id',
            status: 'retracted',
            statusReason:
              'The user explicitly rejected this perspective.',
            supersededById: '',
            confirm: false,
          },
        ],
        keyMemories: [
          {
            id: 'existing-memory-id',
            status: 'archived',
            statusReason:
              'The user explicitly said this information is no longer current.',
            supersededById: '',
          },
        ],
      }),
    ].join('\n')

    const response =
      await client.models.generateContent({
        model,
        contents: prompt,
        config: {
          responseMimeType: 'application/json',
          responseSchema:
            lifecycleResponseSchema,
          maxOutputTokens: 900,
          temperature: 0.1,
        } as any,
      })

    const responseText = response.text?.trim()

    if (!responseText) {
      throw new Error(
        'The lifecycle reconciler returned no data.',
      )
    }

    const parsed = JSON.parse(
      responseText,
    ) as RawReconciliation

    const normalized = parseReconciliation(
      parsed,
      threads,
      goals,
      beliefs,
      keyMemories,
    )

    return {
      source: 'model',
      tokenUsage: getGeminiTokenUsage(response),
      ...normalized,
      error: null,
    }
  } catch (error: unknown) {
    return createEmptyResult(
      'fallback',
      error instanceof Error
        ? error.message
        : 'The lifecycle reconciler was unavailable.',
    )
  }
}
